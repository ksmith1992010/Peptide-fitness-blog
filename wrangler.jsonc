{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "peptide-fitness-blog",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-23",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/*"]
  },
  // Bind SUBSCRIBERS + NEWS_DRAFTS KV in the Cloudflare dashboard after first green deploy.
  // Optional secrets: NEWS_TRIGGER_SECRET, TURNSTILE_SECRET_KEY, STRIPE_SECRET_KEY
  "triggers": {
    "crons": ["0 */6 * * *"]
  },
  "observability": {
    "enabled": true
  }
}
