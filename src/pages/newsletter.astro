---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="Newsletter"
  description="Subscribe to Amino Brief — research reads, tool updates, and peptide-space desk notes."
>
  <Header slot="header" />
  <section class="section">
    <div class="container" style="max-width: 720px;">
      <p class="eyebrow">Stay sharp</p>
      <h1>Newsletter</h1>
      <p class="lede">Sources over hype. Occasional briefs when the peptide world actually moves.</p>
      <div style="margin-top: 2rem;">
        <NewsletterForm />
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
