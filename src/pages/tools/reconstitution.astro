---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReconCalculator from '../../components/tools/ReconCalculator.astro';
---

<BaseLayout
  title="Reconstitution calculator"
  description="Calculate peptide concentration, draw volume, and syringe units from vial strength and bac water."
>
  <Header slot="header" />
  <section class="section">
    <div class="container" style="max-width: 760px;">
      <p class="eyebrow">Tools</p>
      <h1>Reconstitution calculator</h1>
      <p class="lede" style="max-width: 40ch;">
        Plug in vial strength, diluent volume, and a target amount. Get concentration and theoretical syringe marks.
      </p>
      <div style="margin-top: 2rem;">
        <ReconCalculator />
      </div>
      <div class="prose" style="margin-top: 2.5rem;">
        <h2>The formulas</h2>
        <ul>
          <li><code>concentration (mg/mL) = vial mg ÷ water mL</code></li>
          <li><code>volume (mL) = dose mg ÷ concentration</code></li>
          <li><code>U-100 units = volume mL × 100</code></li>
          <li><code>draws per vial = vial mg ÷ dose mg</code></li>
        </ul>
        <p>
          Need bac water or U-100 syringes for your bench kit?
          <a href="/shop">Shop accessories</a>.
        </p>
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
