---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReconCalculator from '../../components/tools/ReconCalculator.astro';
---

<BaseLayout
  title="Reconstitution calculator"
  description="Peptide reconstitution calculator with compound dropdown, duration context, and educational disclaimers."
>
  <Header slot="header" />
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <p class="eyebrow">Tools</p>
      <h1>Reconstitution calculator</h1>
      <p class="lede" style="max-width: 42ch;">
        Pick a peptide, set length-of-use context, then run vial math. Research notes — not a protocol sheet.
      </p>
      <div style="margin-top: 1.5rem;">
        <ReconCalculator />
      </div>
      <div class="prose" style="margin-top: 2.5rem;">
        <h2>The formulas</h2>
        <ul>
          <li><code>concentration (mg/mL) = vial mg ÷ water mL</code></li>
          <li><code>volume (mL) = dose mg ÷ concentration</code></li>
          <li><code>U-100 units = volume mL × 100</code></li>
        </ul>
        <p><a href="/shop">Shop accessories</a> · <a href="/guides/reconstitution-math-without-the-guru">Recon guide</a></p>
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
