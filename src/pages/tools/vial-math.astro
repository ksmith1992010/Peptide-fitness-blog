---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolDisclaimer from '../../components/ToolDisclaimer.astro';
import PeptideControls from '../../components/tools/PeptideControls.astro';
---

<BaseLayout
  title="Vial planner"
  description="Estimate theoretical draws per vial with peptide context, duration notes, and disclaimers."
>
  <Header slot="header" />
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <p class="eyebrow">Tools</p>
      <h1>Vial planner</h1>
      <p class="lede">How many theoretical draws are in the vial at a given amount?</p>

      <div data-smart-vial style="margin-top: 1.5rem;">
        <PeptideControls />
        <ToolDisclaimer />
        <div class="tool-panel" data-vial-calc style="margin-top: 1rem;">
          <div class="tool-grid">
            <div class="field">
              <label for="vial">Vial strength (mg)</label>
              <input id="vial" name="vial" type="number" min="0.1" step="0.1" value="10" />
            </div>
            <div class="field">
              <label for="amt">Amount per draw (mcg)</label>
              <input id="amt" name="amt" type="number" min="1" step="1" value="500" />
            </div>
          </div>
          <div class="result-box" aria-live="polite">
            <dl>
              <dt>Theoretical draws</dt>
              <dd data-out="draws">—</dd>
              <dt>Amount per draw</dt>
              <dd data-out="dose">—</dd>
            </dl>
          </div>
          <p class="disclaimer" style="margin-top: 1rem;">
            Adding more bac water only changes concentration and draw volume — not total peptide in the vial.
          </p>
          <ToolDisclaimer compact />
        </div>
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>

<script>
  function run(root) {
    const vial = Number(root.querySelector('[name="vial"]').value);
    const mcg = Number(root.querySelector('[name="amt"]').value);
    const drawsEl = root.querySelector('[data-out="draws"]');
    const doseEl = root.querySelector('[data-out="dose"]');
    if (!(vial > 0) || !(mcg > 0)) {
      drawsEl.textContent = '—';
      doseEl.textContent = '—';
      return;
    }
    const doseMg = mcg / 1000;
    drawsEl.textContent = `${Number((vial / doseMg).toFixed(1))}`;
    doseEl.textContent = `${mcg} mcg (${Number(doseMg.toFixed(3))} mg)`;
  }

  const wrap = document.querySelector('[data-smart-vial]');
  const root = wrap?.querySelector('[data-vial-calc]');
  if (wrap && root) {
    root.querySelectorAll('input').forEach((el) => el.addEventListener('input', () => run(root)));
    wrap.addEventListener('peptide-change', (event) => {
      const p = event.detail?.peptide;
      if (!p) return;
      root.querySelector('[name="vial"]').value = p.vialMgDefault;
      root.querySelector('[name="amt"]').value = p.referenceAmountMcg;
      run(root);
    });
    run(root);
  }
</script>
