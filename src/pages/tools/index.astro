---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolDisclaimer from '../../components/ToolDisclaimer.astro';

const tools = [
  {
    href: '/tools/reconstitution',
    title: 'Reconstitution calculator',
    body: 'Peptide dropdown + duration context + vial math → concentration and syringe units.',
  },
  {
    href: '/tools/syringe-units',
    title: 'Syringe units converter',
    body: 'Known concentration → U-100 / U-40 marks with research-context notes.',
  },
  {
    href: '/tools/vial-math',
    title: 'Vial planner',
    body: 'Theoretical draws per vial with length-of-use cautions.',
  },
];
---

<BaseLayout title="Tools" description="Peptide reconstitution and syringe tools with compound dropdowns and educational disclaimers.">
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Tools</p>
      <h1>Do the math. Read the caveats.</h1>
      <p class="lede">Every tool includes a peptide selector, duration context, and a not-medical-advice warning.</p>
      <ToolDisclaimer />
      <ul class="link-list" style="margin-top: 2rem;">
        {
          tools.map((t) => (
            <li>
              <a href={t.href}>
                <h3>{t.title}</h3>
                <p style="margin: 0.35rem 0 0; color: var(--mute);">{t.body}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
