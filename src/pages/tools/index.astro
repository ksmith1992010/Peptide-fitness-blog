---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const tools = [
  {
    href: '/tools/reconstitution',
    title: 'Reconstitution calculator',
    body: 'Vial mg + bac water mL → concentration, draw volume, syringe units.',
  },
  {
    href: '/tools/syringe-units',
    title: 'Syringe units converter',
    body: 'Turn a target mcg amount into U-100 / U-40 marks once you know concentration.',
  },
  {
    href: '/tools/vial-math',
    title: 'Vial planner',
    body: 'How many theoretical draws are in a vial at a given amount.',
  },
];
---

<BaseLayout title="Tools" description="Peptide reconstitution and syringe unit calculators — educational math tools.">
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Tools</p>
      <h1>Do the math. Don’t outsource your brain.</h1>
      <p class="lede">Unit conversion for research reconstitution workflows. Not a prescription pad.</p>
      <ul class="link-list" style="margin-top: 2.5rem;">
        {
          tools.map((t) => (
            <li>
              <a href={t.href}>
                <h3>{t.title}</h3>
                <p style="margin: 0.35rem 0 0; color: var(--mute);">{t.body}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
