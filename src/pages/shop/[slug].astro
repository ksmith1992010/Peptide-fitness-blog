---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { products, getProduct } from '../../data/products';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = getProduct(slug!);
if (!product) {
  throw new Error(`Unknown product: ${slug}`);
}
---

<BaseLayout title={product.name} description={product.blurb}>
  <Header slot="header" />
  <section class="section">
    <div class="container" style="max-width: 720px;">
      <p class="eyebrow">Shop · {product.sku}</p>
      <h1 style="max-width: 12ch;">{product.name}</h1>
      <p class="price" style="font-family: var(--font-display); font-size: 2.4rem; margin: 0.5rem 0 1rem;">
        ${product.price}
      </p>
      <p class="lede" style="max-width: 40ch;">{product.blurb}</p>
      <ul>
        {product.details.map((d) => <li>{d}</li>)}
      </ul>

      <div class="tool-panel" style="margin-top: 2rem;">
        <h2 style="font-size: 1.4rem;">Request an order</h2>
        <p style="color: var(--mute);">
          Stripe checkout comes next. For now this opens an email draft with your order details.
        </p>
        <form id="shop-order" data-product={product.name} data-sku={product.sku} data-price={product.price}>
          <div class="tool-grid" style="margin-top: 1rem;">
            <div class="field">
              <label for="name">Name</label>
              <input id="name" name="name" required />
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div class="field">
              <label for="qty">Quantity</label>
              <input id="qty" name="qty" type="number" min="1" value="1" required />
            </div>
            <div class="field">
              <label for="notes">Notes</label>
              <input id="notes" name="notes" placeholder="Shipping preference, questions…" />
            </div>
          </div>
          <button class="btn btn-primary" type="submit" style="margin-top: 1rem;">Email order request</button>
        </form>
      </div>

      <p class="disclaimer" style="margin-top: 1.5rem;">
        Accessories for research / educational workflows. Amino Brief does not sell peptides and does not provide
        medical or injection advice.
      </p>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>

<script>
  const form = document.getElementById('shop-order');
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const product = form.dataset.product;
    const sku = form.dataset.sku;
    const price = form.dataset.price;
    const name = String(data.get('name') || '');
    const email = String(data.get('email') || '');
    const qty = String(data.get('qty') || '1');
    const notes = String(data.get('notes') || '');
    const subject = encodeURIComponent(`Amino Brief order: ${product} × ${qty}`);
    const body = encodeURIComponent(
      [
        `Product: ${product} (${sku})`,
        `Price: $${price}`,
        `Qty: ${qty}`,
        `Name: ${name}`,
        `Email: ${email}`,
        `Notes: ${notes}`,
      ].join('\n'),
    );
    window.location.href = `mailto:orders@aminobrief.com?subject=${subject}&body=${body}`;
  });
</script>
