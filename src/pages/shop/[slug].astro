---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { products, getProduct, stripeCheckoutSlugs } from '../../data/products';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = getProduct(slug!);
if (!product) {
  throw new Error(`Unknown product: ${slug}`);
}

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.blurb,
  sku: product.sku,
  image: new URL(product.image, Astro.site).toString(),
  brand: { '@type': 'Brand', name: 'Amino Brief' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'USD',
    price: product.price,
    availability: 'https://schema.org/PreOrder',
    url: new URL(`/shop/${product.slug}`, Astro.site).toString(),
  },
};
---

<BaseLayout
  title={
    product.slug === 'bac-water'
      ? 'Bacteriostatic water for reconstitution (30 mL)'
      : product.slug === 'insulin-syringes'
        ? 'U-100 insulin syringes for reconstitution math'
        : product.name
  }
  description={product.blurb}
  ogImage={product.image}
  jsonLd={productSchema}
>
  <Header slot="header" />
  <section class="section">
    <div class="container" style="max-width: 720px;">
      <p class="eyebrow">Shop · {product.sku} · {product.category}</p>
      <h1 style="max-width: 16ch;">{product.name}</h1>
      <img
        class="product-hero"
        src={product.image}
        alt={product.imageAlt}
        width="900"
        height="900"
        style="width: 100%; max-width: 420px; aspect-ratio: 1; object-fit: cover; margin: 1.25rem 0; border: 1px solid var(--line); background: var(--paper-2);"
      />
      <p class="price" style="font-family: var(--font-display); font-size: 2.4rem; margin: 0.5rem 0 0.35rem;">
        ${product.price}
      </p>
      <p style="font-family: var(--font-ui); color: var(--mute); margin: 0 0 1rem;">
        Retail MOQ: <strong>{product.moq}</strong>
        {
          product.resellerPrice && (
            <>
              {' '}
              · Reseller from <strong>${product.resellerPrice}</strong> (qty 6+)
            </>
          )
        }
        {
          product.wholesalePrice && product.wholesaleMoq && (
            <>
              {' '}
              · Wholesale from <strong>${product.wholesalePrice}</strong> (qty {product.wholesaleMoq}+)
            </>
          )
        }
      </p>
      <p class="lede" style="max-width: 40ch;">{product.blurb}</p>
      <ul>
        {product.details.map((d) => <li>{d}</li>)}
      </ul>
      <p style="font-family: var(--font-ui); font-size: 0.9rem; color: var(--mute);">
        <strong>Sourcing:</strong> {product.supplierNote}
      </p>

      {
        stripeCheckoutSlugs.includes(product.slug as (typeof stripeCheckoutSlugs)[number]) && (
          <div class="tool-panel" style="margin-top: 2rem;" data-stripe-panel data-checkout-sku={product.slug}>
            <h2 style="font-size: 1.4rem;">Card checkout</h2>
            <p style="color: var(--mute);" data-stripe-blurb>
              Retail Stripe Checkout when this SKU is priced in Worker secrets. Reseller / wholesale MOQs still use the
              email request below.
            </p>
            <div class="tool-grid" style="margin-top: 1rem;">
              <div class="field">
                <label for="stripe-qty">Quantity</label>
                <input id="stripe-qty" name="stripe-qty" type="number" min="1" max="100" value="1" />
              </div>
            </div>
            <button class="btn btn-primary" type="button" data-stripe-checkout style="margin-top: 1rem;" disabled>
              Checking card checkout…
            </button>
            <p data-stripe-status role="status" aria-live="polite" style="font-family: var(--font-ui); margin: 0.75rem 0 0;"></p>
          </div>
        )
      }

      <div class="tool-panel" style="margin-top: 2rem;">
        <h2 style="font-size: 1.4rem;">MOQ order request</h2>
        <p style="color: var(--mute);">
          Select quantity to see tier. Opens an email draft with MOQ / reseller details.
        </p>
        <form
          id="shop-order"
          data-product={product.name}
          data-sku={product.sku}
          data-price={product.price}
          data-reseller={product.resellerPrice ?? ''}
          data-wholesale={product.wholesalePrice ?? ''}
          data-wholesale-moq={product.wholesaleMoq ?? ''}
        >
          <div class="tool-grid" style="margin-top: 1rem;">
            <div class="field">
              <label for="name">Name</label>
              <input id="name" name="name" required />
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div class="field">
              <label for="qty">Quantity (MOQ {product.moq})</label>
              <input id="qty" name="qty" type="number" min={product.moq} value={product.moq} required />
            </div>
            <div class="field">
              <label for="tier">Intent</label>
              <select id="tier" name="tier">
                <option value="retail">Retail</option>
                <option value="reseller">Reseller</option>
                <option value="wholesale">Wholesale</option>
              </select>
            </div>
            <div class="field" style="grid-column: 1 / -1;">
              <label for="notes">Notes</label>
              <input id="notes" name="notes" placeholder="Shipping, storefront URL, tax ID…" />
            </div>
          </div>
          <p data-tier-preview style="font-family: var(--font-ui); margin: 0.75rem 0 0;"></p>
          <button class="btn btn-primary" type="submit" style="margin-top: 1rem;">Email order request</button>
        </form>
      </div>

      <p class="disclaimer" style="margin-top: 1.5rem;">
        Accessories only. Catalog images are studio pack-shots for merchandising; swap to received-pack photography when
        inventory lands. Amino Brief does not sell peptides and does not provide medical or injection advice.
      </p>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>

<script>
  const form = document.getElementById('shop-order');
  const preview = document.querySelector('[data-tier-preview]');
  function tierPrice(qty) {
    const retail = Number(form.dataset.price);
    const reseller = Number(form.dataset.reseller || 0);
    const wholesale = Number(form.dataset.wholesale || 0);
    const wMoq = Number(form.dataset.wholesaleMoq || 0);
    if (wholesale && wMoq && qty >= wMoq) return { unit: wholesale, tier: 'wholesale' };
    if (reseller && qty >= 6) return { unit: reseller, tier: 'reseller' };
    return { unit: retail, tier: 'retail' };
  }
  function updatePreview() {
    if (!form || !preview) return;
    const qty = Number(form.qty.value || 1);
    const { unit, tier } = tierPrice(qty);
    preview.textContent = `Est. ${tier} unit ~$${unit} · line ~$${(unit * qty).toFixed(2)} (confirm on reply)`;
  }
  form?.qty.addEventListener('input', updatePreview);
  updatePreview();
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const qty = Number(data.get('qty') || 1);
    const { unit, tier } = tierPrice(qty);
    const subject = encodeURIComponent(`Amino Brief order: ${form.dataset.product} × ${qty} (${tier})`);
    const body = encodeURIComponent(
      [
        `Product: ${form.dataset.product} (${form.dataset.sku})`,
        `Qty: ${qty}`,
        `Intent: ${data.get('tier')}`,
        `Estimated tier: ${tier} @ $${unit}`,
        `Name: ${data.get('name')}`,
        `Email: ${data.get('email')}`,
        `Notes: ${data.get('notes') || ''}`,
      ].join('\n'),
    );
    window.location.href = `mailto:orders@aminobrief.com?subject=${subject}&body=${body}`;
  });

  const stripePanel = document.querySelector('[data-stripe-panel]');
  const stripeBtn = document.querySelector('[data-stripe-checkout]');
  const stripeStatus = document.querySelector('[data-stripe-status]');
  const stripeBlurb = document.querySelector('[data-stripe-blurb]');
  const params = new URLSearchParams(window.location.search);
  if (stripeStatus && params.get('checkout') === 'success') {
    stripeStatus.textContent = 'Payment started successfully — check your email from Stripe for the receipt.';
  }
  if (stripeStatus && params.get('checkout') === 'cancel') {
    stripeStatus.textContent = 'Checkout canceled. Email order request still works below.';
  }

  async function refreshStripeAvailability() {
    if (!stripePanel || !(stripeBtn instanceof HTMLButtonElement)) return;
    const sku = stripePanel.getAttribute('data-checkout-sku');
    try {
      const res = await fetch('/api/checkout/priced');
      const json = await res.json().catch(() => ({}));
      const priced = Array.isArray(json.pricedSkus) ? json.pricedSkus : [];
      const live = sku && priced.includes(sku);
      if (live) {
        stripeBtn.disabled = false;
        stripeBtn.textContent = 'Pay with card';
        if (stripeBlurb) {
          stripeBlurb.textContent =
            'Card checkout is live for this SKU. Reseller / wholesale MOQs still use the email request below.';
        }
      } else {
        stripeBtn.disabled = true;
        stripeBtn.textContent = 'Card checkout not priced yet';
        if (stripeBlurb) {
          stripeBlurb.textContent =
            'Stripe secret / price ID not set for this SKU yet. Use the email order request below (see docs/OPS-INTEGRATIONS.md).';
        }
      }
    } catch {
      stripeBtn.disabled = false;
      stripeBtn.textContent = 'Pay with card';
    }
  }
  refreshStripeAvailability();

  stripeBtn?.addEventListener('click', async () => {
    if (!stripePanel || !stripeStatus) return;
    if (stripeBtn instanceof HTMLButtonElement && stripeBtn.disabled) return;
    const sku = stripePanel.getAttribute('data-checkout-sku');
    const qtyInput = document.getElementById('stripe-qty');
    const quantity = Number(qtyInput?.value || 1);
    stripeStatus.textContent = 'Starting Stripe Checkout…';
    try {
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sku, quantity }),
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(json.error || 'Checkout unavailable');
      if (!json.url) throw new Error('No checkout URL returned');
      window.location.href = json.url;
    } catch (err) {
      stripeStatus.textContent =
        err instanceof Error
          ? err.message
          : 'Checkout unavailable. Use the email order request below.';
    }
  });
</script>
