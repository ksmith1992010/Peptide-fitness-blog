---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { seoClusters } from '../data/seo-clusters';
---

<BaseLayout
  title="SEO & organic growth"
  description="What actually works for Amino Brief organic traffic: YMYL-safe literacy clusters, E-E-A-T, citation outreach — not buy-peptide SERPs."
  noindex={true}
>
  <Header slot="header" />
  <section class="section">
    <div class="container prose">
      <p class="eyebrow">Growth systems</p>
      <h1>SEO that fits this niche</h1>
      <p>
        Peptide content is YMYL-adjacent. Google rewards E-E-A-T, primary sources, and clear non-medical boundaries.
        We do <strong>not</strong> compete on “buy BPC-157” or dosing protocols — we sell accessories and publish
        literacy.
      </p>

      <h2>What works (scrubbed)</h2>
      <ul>
        <li>Educational intent clusters (COA, RUO, evidence tiers, compound “what the research shows”)</li>
        <li>Compound hubs + snapshot guides with honest evidence badges</li>
        <li>Author / editorial / review-seat disclosure (no fake clinician badges)</li>
        <li>Citation outreach of original explainers (.edu lists, journalism, newsletters)</li>
        <li>Clean definitions + FAQ for AI Overviews / answer engines</li>
        <li><code>llms.txt</code> / <code>llms-full.txt</code> kept current</li>
      </ul>

      <h2>What doesn’t</h2>
      <ul>
        <li>Protocol porn and implied medical claims</li>
        <li>PBN / fake medical citations</li>
        <li>Thin duplicate snapshots with no sources</li>
        <li>Keyword cannibalization between shop and education pages</li>
      </ul>

      <h2>Live clusters</h2>
      <ul>
        {
          seoClusters.map((c) => (
            <li>
              <a href={c.hubPath}>{c.name}</a> — {c.intent}
            </li>
          ))
        }
      </ul>

      <h2>On-site systems</h2>
      <ul>
        <li><code>/sitemap-index.xml</code></li>
        <li><code>/rss</code> (+ <code>/rss.xml</code> alias)</li>
        <li><code>/llms.txt</code> + <code>/llms-full.txt</code></li>
        <li>JSON-LD: Organization, WebSite, Article, Product, BreadcrumbList, FAQ where useful</li>
        <li><a href="/editorial">Editorial</a> · <a href="/authors">Authors</a> · <a href="/resources/sourcing-notes">Sourcing notes</a></li>
      </ul>

      <h2>Outreach</h2>
      <p>
        Ops tracker with copy-paste pitches (noindex): <a href="/outreach">/outreach</a>. Plan detail:
        <code>docs/GROWTH-PLAN.md</code>.
      </p>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
