---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Resources" description="External references for peptide literacy — PubMed, FDA, and quality documentation primers.">
  <Header slot="header" />
  <section class="section">
    <div class="container prose">
      <p class="eyebrow">Resources</p>
      <h1>Where to dig deeper</h1>
      <p>
        Primary sources beat influencer slideshows. Any catalog link here is labeled and criteria-first — not a storefront
        and not medical advice.
      </p>
      <ul>
        <li><a href="https://pubmed.ncbi.nlm.nih.gov/" rel="noopener noreferrer">PubMed</a> — find the actual papers</li>
        <li><a href="https://clinicaltrials.gov/" rel="noopener noreferrer">ClinicalTrials.gov</a> — see what’s been studied in humans</li>
        <li><a href="https://www.fda.gov/" rel="noopener noreferrer">FDA</a> — approvals, safety communications, compounding context</li>
        <li><a href="/resources/sourcing-notes">Amino Brief: Sourcing notes</a> — standing quality criteria</li>
        <li><a href="/authors">Amino Brief: Authors & clinical review seat</a></li>
        <li><a href="/guides/how-to-read-a-coa">Amino Brief: How to read a COA</a></li>
        <li><a href="/guides/how-to-evaluate-a-peptide-source">Amino Brief: How to evaluate a source</a></li>
        <li><a href="/evidence">Amino Brief: Evidence grades</a></li>
        <li><a href="/compounds">Amino Brief: Compound hubs</a></li>
        <li><a href="/faq">Amino Brief: FAQ</a></li>
        <li><a href="/glossary">Amino Brief: Glossary</a></li>
        <li>
          <a href="https://peperchini.com" rel="noopener noreferrer">Peperchini</a> — soft, criteria-first documentation
          example in our sourcing guide (not an Amino Brief storefront; not medical advice)
        </li>
      </ul>
      <p style="font-family: var(--font-ui); font-size: 0.9rem; color: var(--mute);">
        Always prefer PubMed / trials / FDA over any catalog. See
        <a href="/guides/how-to-evaluate-a-peptide-source">How to evaluate a peptide source</a>.
      </p>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
