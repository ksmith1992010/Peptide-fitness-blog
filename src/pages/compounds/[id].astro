---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EvidenceBadge from '../../components/EvidenceBadge.astro';
import ToolDisclaimer from '../../components/ToolDisclaimer.astro';
import { peptides, durationOptions, getPeptide } from '../../data/peptides';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return peptides.filter((p) => p.id !== 'generic').map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const compound = getPeptide(id!);
const guides = await getCollection('guides');
const needle = compound.name.split(/[\s/]/)[0].toLowerCase();
const related = guides.filter(
  (g) =>
    g.id.includes(needle) ||
    g.data.title.toLowerCase().includes(needle) ||
    g.data.tags.some((t) => t.toLowerCase().includes(needle)) ||
    (compound.id === 'bpc-157' && g.id.includes('bpc')) ||
    (compound.id === 'mots-c' && g.id.includes('mots')) ||
    (compound.id === 'retatrutide' && g.id.includes('retatrutide')) ||
    (compound.id === 'tesamorelin' && g.id.includes('tesamorelin')) ||
    (compound.id === 'tb-500' && g.id.includes('tb-500')) ||
    (compound.id === 'cjc-ipa' && (g.id.includes('cjc') || g.id.includes('ipa'))) ||
    (compound.id === 'ghk-cu' && g.id.includes('ghk')),
);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${compound.name} — research literacy hub`,
  description: compound.summary,
  about: compound.name,
  dateModified: new Date().toISOString().slice(0, 10),
  audience: 'https://schema.org/Researcher',
};
---

<BaseLayout
  title={`${compound.name} research hub`}
  description={compound.summary}
  jsonLd={pageSchema}
>
  <Header slot="header" />
  <article class="section">
    <div class="container" style="max-width: 800px;">
      <p class="eyebrow">{compound.category}</p>
      <h1 style="max-width: 12ch;">{compound.name}</h1>
      <div style="margin: 1rem 0; display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
        <EvidenceBadge level={compound.evidence} />
        <span style="font-family: var(--font-ui); font-size: 0.85rem; color: var(--mute);">
          Sources: {compound.sourcesHint}
        </span>
      </div>
      <p class="lede">{compound.summary}</p>
      <ToolDisclaimer />

      <div class="prose">
        <h2>Duration context</h2>
        {
          durationOptions.map((d) => (
            <div style="margin-bottom: 1rem;">
              <h3 style="font-size: 1.15rem;">{d.label}</h3>
              <p style="color: var(--mute); margin: 0 0 0.35rem;">{d.blurb}</p>
              <p>{compound.durationNotes[d.id]}</p>
            </div>
          ))
        }

        <h2>Cautions</h2>
        <ul>
          {compound.cautions.map((c) => <li>{c}</li>)}
        </ul>

        <h2>Run the math</h2>
        <p>
          Defaults for tools: {compound.vialMgDefault} mg vial · {compound.bacWaterMlDefault} mL bac water ·{' '}
          {compound.referenceAmountMcg} mcg reference amount (educational only).
        </p>
      </div>

      <div class="btn-row">
        <a class="btn btn-primary" href={`/tools/reconstitution`}>Reconstitution calculator</a>
        <a class="btn btn-secondary" href="/tools">All tools</a>
      </div>

      {
        related.length > 0 && (
          <div style="margin-top: 2.5rem;">
            <h2>Related guides</h2>
            <ul class="link-list">
              {related.map((g) => (
                <li>
                  <a href={`/guides/${g.id}`}>
                    <h3>{g.data.title}</h3>
                    <p style="margin: 0.35rem 0 0; color: var(--mute);">{g.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </article>
  <Footer slot="footer" />
</BaseLayout>
