---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EvidenceBadge from '../../components/EvidenceBadge.astro';
import ToolDisclaimer from '../../components/ToolDisclaimer.astro';
import { peptides, durationOptions, getPeptide } from '../../data/peptides';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return peptides.filter((p) => p.id !== 'generic').map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const compound = getPeptide(id!);
const guides = await getCollection('guides');
const needle = compound.name.split(/[\s/]/)[0].toLowerCase();
const related = guides.filter(
  (g) =>
    g.id.includes(needle) ||
    g.data.title.toLowerCase().includes(needle) ||
    g.data.tags.some((t) => t.toLowerCase().includes(needle)) ||
    (compound.id === 'bpc-157' && g.id.includes('bpc')) ||
    (compound.id === 'mots-c' && g.id.includes('mots')) ||
    (compound.id === 'retatrutide' && g.id.includes('retatrutide')) ||
    (compound.id === 'tesamorelin' && g.id.includes('tesamorelin')) ||
    (compound.id === 'tb-500' && g.id.includes('tb-500')) ||
    (compound.id === 'cjc-ipa' && (g.id.includes('cjc') || g.id.includes('ipa'))) ||
    (compound.id === 'ghk-cu' && g.id.includes('ghk')),
);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${compound.name} — research literacy hub`,
  description: compound.summary,
  about: compound.name,
  dateModified: new Date().toISOString().slice(0, 10),
  audience: 'https://schema.org/Researcher',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: new URL('/', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Compounds',
      item: new URL('/compounds', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: compound.name,
      item: new URL(`/compounds/${compound.id}`, Astro.site).toString(),
    },
  ],
};
---

<BaseLayout
  title={`${compound.name} research hub`}
  description={compound.summary}
  jsonLd={[pageSchema, breadcrumbSchema]}
>
  <Header slot="header" />
  <article class="section">
    <div class="container" style="max-width: 800px;">
      <p class="eyebrow" style="font-family: var(--font-ui);">
        <a href="/compounds" style="color: inherit;">Compounds</a>
        <span aria-hidden="true"> / </span>
        {compound.category}
      </p>
      <h1 style="max-width: 12ch;">{compound.name}</h1>
      <div class="compound-trust">
        <div class="compound-trust-row">
          <EvidenceBadge level={compound.evidence} />
          <a href="/evidence">Evidence grades</a>
        </div>
        <p class="sources-line">
          <strong>Where to dig:</strong> {compound.sourcesHint}
        </p>
      </div>
      <p class="lede">{compound.summary}</p>
      <ToolDisclaimer />

      <div class="btn-row" style="margin: 1.5rem 0 2rem;">
        <a class="btn btn-primary" href="/guides?cluster=compounds">Related literacy</a>
        <a class="btn btn-secondary" href="/resources/sourcing-notes">Sourcing notes</a>
        <a class="btn btn-secondary" href="/tools/reconstitution">Recon calculator</a>
      </div>

      <div class="prose">
        <h2>Duration context</h2>
        {
          durationOptions.map((d) => (
            <div style="margin-bottom: 1rem;">
              <h3 style="font-size: 1.15rem;">{d.label}</h3>
              <p style="color: var(--mute); margin: 0 0 0.35rem;">{d.blurb}</p>
              <p>{compound.durationNotes[d.id]}</p>
            </div>
          ))
        }

        <h2>Cautions</h2>
        <ul>
          {compound.cautions.map((c) => <li>{c}</li>)}
        </ul>

        <h2>Educational tool defaults</h2>
        <p>
          Defaults for unit-math tools: {compound.vialMgDefault} mg vial · {compound.bacWaterMlDefault} mL bac water ·{' '}
          {compound.referenceAmountMcg} mcg reference amount. Not a prescription.
        </p>
      </div>

      {
        related.length > 0 && (
          <div style="margin-top: 2.5rem;">
            <h2>Related guides</h2>
            <ul class="link-list">
              {related.map((g) => (
                <li>
                  <a href={`/guides/${g.id}`}>
                    <h3>{g.data.title}</h3>
                    <p style="margin: 0.35rem 0 0; color: var(--mute);">{g.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <div class="btn-row" style="margin-top: 2rem;">
        <a class="btn btn-secondary" href="/learn">All learning paths</a>
        <a class="btn btn-secondary" href="/tools">All tools</a>
      </div>
    </div>
  </article>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .compound-trust {
    display: grid;
    gap: 0.5rem;
    margin: 1rem 0 1.25rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
  }

  .compound-trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .sources-line {
    margin: 0;
    color: var(--ink-soft);
  }
</style>
