---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EvidenceBadge from '../../components/EvidenceBadge.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryFilters = [
  { id: 'all', label: 'All' },
  { id: 'safety', label: 'Safety' },
  { id: 'comparison', label: 'Comparison' },
  { id: 'protocol', label: 'Protocol' },
  { id: 'planner', label: 'Planner' },
  { id: 'basics', label: 'Basics' },
  { id: 'quality', label: 'Quality' },
];

const evidenceFilters = [
  { id: 'all', label: 'Any evidence' },
  { id: 'fda-approved', label: 'FDA context' },
  { id: 'human', label: 'Human' },
  { id: 'mixed', label: 'Mixed' },
  { id: 'animal', label: 'Animal' },
  { id: 'literacy', label: 'Literacy' },
];

const initialQ = Astro.url.searchParams.get('q')?.trim() ?? '';
---

<BaseLayout title="Guides" description="Evidence-tagged peptide awareness guides — safety, quality, comparisons, and basics.">
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Guides</p>
      <h1>Research notes with receipts</h1>
      <p class="lede">Filter by topic or evidence. Every piece carries a badge so you know what kind of claim you’re looking at.</p>

      <div class="field" style="max-width: 28rem; margin-top: 1.25rem;">
        <label for="guide-search">Search</label>
        <input id="guide-search" type="search" placeholder="COA, retatrutide, storage…" value={initialQ} data-guide-search />
      </div>

      <div class="pill-filters" role="toolbar" aria-label="Guide category filters" data-guide-filters style="margin-top: 1rem;">
        {
          categoryFilters.map((f) => (
            <button type="button" data-filter={f.id} aria-pressed={f.id === 'all' ? 'true' : 'false'}>
              {f.label}
            </button>
          ))
        }
      </div>

      <div class="pill-filters" role="toolbar" aria-label="Evidence filters" data-evidence-filters style="margin-top: 0.5rem;">
        {
          evidenceFilters.map((f) => (
            <button type="button" data-evidence={f.id} aria-pressed={f.id === 'all' ? 'true' : 'false'}>
              {f.label}
            </button>
          ))
        }
      </div>

      <p data-guide-count style="font-family: var(--font-ui); color: var(--mute); margin: 1rem 0 0;"></p>

      <ul class="link-list" data-guide-list>
        {
          guides.map((guide) => (
            <li
              data-category={guide.data.category}
              data-evidence={guide.data.evidence}
              data-search={`${guide.data.title} ${guide.data.description} ${guide.data.tags.join(' ')} ${guide.id}`.toLowerCase()}
            >
              <a href={`/guides/${guide.id}`}>
                <div class="meta">
                  <EvidenceBadge level={guide.data.evidence} />
                  <span style="margin-left: 0.5rem; text-transform: uppercase; letter-spacing: 0.08em;">
                    {guide.data.category}
                  </span>
                  <span style="margin-left: 0.5rem;">
                    {guide.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </span>
                </div>
                <h3>{guide.data.title}</h3>
                <p style="margin: 0.35rem 0 0; color: var(--mute);">{guide.data.description}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>

<script>
  const categoryToolbar = document.querySelector('[data-guide-filters]');
  const evidenceToolbar = document.querySelector('[data-evidence-filters]');
  const list = document.querySelector('[data-guide-list]');
  const search = document.querySelector('[data-guide-search]');
  const count = document.querySelector('[data-guide-count]');
  let category = 'all';
  let evidence = 'all';

  function apply() {
    if (!list) return;
    const q = (search?.value || '').trim().toLowerCase();
    let visible = 0;
    list.querySelectorAll('li[data-category]').forEach((item) => {
      const el = item;
      const catOk = category === 'all' || el.dataset.category === category;
      const evOk = evidence === 'all' || el.dataset.evidence === evidence;
      const qOk = !q || (el.dataset.search || '').includes(q);
      const show = catOk && evOk && qOk;
      el.hidden = !show;
      if (show) visible += 1;
    });
    if (count) count.textContent = `${visible} guide${visible === 1 ? '' : 's'} shown`;
    const url = new URL(window.location.href);
    if (q) url.searchParams.set('q', q);
    else url.searchParams.delete('q');
    window.history.replaceState({}, '', url);
  }

  categoryToolbar?.addEventListener('click', (event) => {
    const btn = event.target.closest('button[data-filter]');
    if (!btn) return;
    category = btn.dataset.filter || 'all';
    categoryToolbar.querySelectorAll('button').forEach((b) => {
      b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
    });
    apply();
  });

  evidenceToolbar?.addEventListener('click', (event) => {
    const btn = event.target.closest('button[data-evidence]');
    if (!btn) return;
    evidence = btn.dataset.evidence || 'all';
    evidenceToolbar.querySelectorAll('button').forEach((b) => {
      b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
    });
    apply();
  });

  search?.addEventListener('input', apply);
  apply();
</script>
