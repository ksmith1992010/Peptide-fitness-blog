---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EvidenceBadge from '../../components/EvidenceBadge.astro';
import { getCollection } from 'astro:content';
import { clusterIdForGuide, seoClusters } from '../../data/seo-clusters';

const guides = (await getCollection('guides')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const clusterFilters = [
  { id: 'all', label: 'All' },
  ...seoClusters
    .filter((c) => c.id !== 'accessories')
    .map((c) => ({ id: c.id, label: c.shortLabel })),
];

const evidenceFilters = [
  { id: 'all', label: 'Any evidence' },
  { id: 'fda-approved', label: 'FDA context' },
  { id: 'human', label: 'Human' },
  { id: 'mixed', label: 'Mixed' },
  { id: 'animal', label: 'Animal' },
  { id: 'literacy', label: 'Literacy' },
];

const initialQ = Astro.url.searchParams.get('q')?.trim() ?? '';
const initialCluster = Astro.url.searchParams.get('cluster')?.trim() || 'all';
---

<BaseLayout
  title="Guides"
  description="Evidence-tagged peptide awareness guides — literacy, sourcing, compounds, media, and methods desk briefs."
>
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Guides</p>
      <h1>Research notes with receipts</h1>
      <p class="lede">
        Filter by learning path or evidence grade. Every piece carries a badge so you know what kind of claim you’re
        looking at.
      </p>

      <div class="field" style="max-width: 28rem; margin-top: 1.25rem;">
        <label for="guide-search">Search</label>
        <input
          id="guide-search"
          type="search"
          placeholder="COA, retatrutide, cyclic peptide…"
          value={initialQ}
          data-guide-search
        />
      </div>

      <div class="cluster-filters" role="toolbar" aria-label="Guide path filters" data-guide-filters style="margin-top: 1rem;">
        {
          clusterFilters.map((f) => (
            <button
              type="button"
              data-filter={f.id}
              aria-pressed={f.id === initialCluster ? 'true' : 'false'}
            >
              {f.label}
            </button>
          ))
        }
      </div>

      <div class="field" style="max-width: 16rem; margin-top: 0.75rem;">
        <label for="evidence-filter">Evidence</label>
        <select id="evidence-filter" data-evidence-select>
          {evidenceFilters.map((f) => <option value={f.id}>{f.label}</option>)}
        </select>
      </div>

      <p data-guide-count style="font-family: var(--font-ui); color: var(--mute); margin: 1rem 0 0;"></p>

      <ul class="link-list" data-guide-list>
        {
          guides.map((guide) => {
            const cluster = clusterIdForGuide(guide);
            const clusterLabel = seoClusters.find((c) => c.id === cluster)?.shortLabel || 'Literacy';
            return (
              <li
                data-cluster={cluster}
                data-evidence={guide.data.evidence}
                data-search={`${guide.data.title} ${guide.data.description} ${guide.data.tags.join(' ')} ${guide.id} ${clusterLabel}`.toLowerCase()}
              >
                <a href={`/guides/${guide.id}`}>
                  <div class="meta">
                    <EvidenceBadge level={guide.data.evidence} />
                    <span style="margin-left: 0.5rem; text-transform: uppercase; letter-spacing: 0.08em;">
                      {clusterLabel}
                    </span>
                  </div>
                  <h3>{guide.data.title}</h3>
                  <p style="margin: 0.35rem 0 0; color: var(--mute);">{guide.data.description}</p>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>

<script>
  const categoryToolbar = document.querySelector('[data-guide-filters]');
  const evidenceSelect = document.querySelector('[data-evidence-select]');
  const list = document.querySelector('[data-guide-list]');
  const search = document.querySelector('[data-guide-search]');
  const count = document.querySelector('[data-guide-count]');
  const params = new URLSearchParams(window.location.search);
  let cluster = params.get('cluster') || 'all';
  let evidence = 'all';

  if (evidenceSelect instanceof HTMLSelectElement) {
    evidenceSelect.value = 'all';
  }

  function syncClusterButtons() {
    categoryToolbar?.querySelectorAll('button').forEach((b) => {
      b.setAttribute('aria-pressed', b.getAttribute('data-filter') === cluster ? 'true' : 'false');
    });
  }
  syncClusterButtons();

  function apply() {
    if (!list) return;
    const q = (search instanceof HTMLInputElement ? search.value : '').trim().toLowerCase();
    let visible = 0;
    list.querySelectorAll('li[data-cluster]').forEach((item) => {
      const el = item;
      const clusterOk = cluster === 'all' || el.dataset.cluster === cluster;
      const evOk = evidence === 'all' || el.dataset.evidence === evidence;
      const qOk = !q || (el.dataset.search || '').includes(q);
      const show = clusterOk && evOk && qOk;
      el.hidden = !show;
      if (show) visible += 1;
    });
    if (count) count.textContent = `${visible} guide${visible === 1 ? '' : 's'} shown`;
    const url = new URL(window.location.href);
    if (q) url.searchParams.set('q', q);
    else url.searchParams.delete('q');
    if (cluster && cluster !== 'all') url.searchParams.set('cluster', cluster);
    else url.searchParams.delete('cluster');
    window.history.replaceState({}, '', url);
  }

  categoryToolbar?.addEventListener('click', (event) => {
    const btn = event.target.closest('button[data-filter]');
    if (!btn) return;
    cluster = btn.dataset.filter || 'all';
    syncClusterButtons();
    apply();
  });

  evidenceSelect?.addEventListener('change', () => {
    evidence = evidenceSelect instanceof HTMLSelectElement ? evidenceSelect.value : 'all';
    apply();
  });

  search?.addEventListener('input', apply);
  apply();
</script>
