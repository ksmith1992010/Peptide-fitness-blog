---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EvidenceBadge from '../../components/EvidenceBadge.astro';
import { getCollection, render } from 'astro:content';
import { getAuthor } from '../../data/authors';
import { continuePathsForGuide, clusterIdForGuide, seoClusters } from '../../data/seo-clusters';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { id: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const updated = guide.data.updatedDate ?? guide.data.pubDate;
const author = getAuthor(guide.data.authorId) ?? getAuthor('editorial')!;
const reviewer = guide.data.reviewedById ? getAuthor(guide.data.reviewedById) : undefined;

const reviewLabel =
  guide.data.reviewStatus === 'reviewed' && reviewer
    ? `Clinician-reviewed by ${reviewer.name}`
    : guide.data.reviewStatus === 'pending'
      ? 'Clinical review pending'
      : 'Editorial review only — not clinician-reviewed';

const clusterId = clusterIdForGuide(guide);
const clusterLabel = seoClusters.find((c) => c.id === clusterId)?.shortLabel || 'Literacy';
const continueLinks = continuePathsForGuide(guide);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.description,
  datePublished: guide.data.pubDate.toISOString(),
  dateModified: updated.toISOString(),
  author: {
    '@type': 'Organization',
    name: author.name,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Amino Brief',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/logo.svg', Astro.site).toString(),
    },
  },
  mainEntityOfPage: new URL(`/guides/${guide.id}`, Astro.site).toString(),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `What does Amino Brief cover in “${guide.data.title}”?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${guide.data.description} Educational research literacy only — not medical advice or a protocol.`,
      },
    },
    {
      '@type': 'Question',
      name: `What evidence grade is “${guide.data.title}”?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Tagged ${guide.data.evidence}. Amino Brief separates FDA-approved context, human evidence, mixed evidence, animal/preclinical work, anecdotal claims, and literacy how-tos.`,
      },
    },
    {
      '@type': 'Question',
      name: `Was “${guide.data.title}” clinician-reviewed?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${reviewLabel}. Seat status: https://aminobrief.com/authors`,
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: new URL('/', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Guides',
      item: new URL('/guides', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: guide.data.title,
      item: new URL(`/guides/${guide.id}`, Astro.site).toString(),
    },
  ],
};
---

<BaseLayout
  title={guide.data.title}
  description={guide.data.description}
  ogType="article"
  jsonLd={[articleSchema, faqSchema, breadcrumbSchema]}
>
  <Header slot="header" />
  <article class="section">
    <div class="container">
      <p class="eyebrow" style="font-family: var(--font-ui);">
        <a href="/guides" style="color: inherit;">Guides</a>
        <span aria-hidden="true"> / </span>
        <a href={`/guides?cluster=${clusterId}`} style="color: inherit;">{clusterLabel}</a>
      </p>
      <h1 style="max-width: 14ch;">{guide.data.title}</h1>
      <div class="guide-trust">
        <div class="guide-trust-row">
          <EvidenceBadge level={guide.data.evidence} />
          <a href="/evidence">How grades work</a>
        </div>
        <div class="guide-trust-row mute">
          <span>
            Updated {
              updated.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })
            }
          </span>
          <span aria-hidden="true">·</span>
          <a href="/authors">By {author.name}</a>
        </div>
        <p class="guide-review">{reviewLabel}</p>
      </div>
      <p class="lede" style="max-width: 42ch;">{guide.data.description}</p>
      <div class="prose" style="margin-top: 2rem;">
        <Content />
        {
          guide.data.sources.length > 0 && (
            <>
              <h2>Sources</h2>
              <ul>
                {guide.data.sources.map((s) => (
                  <li>
                    <a href={s.url} rel="noopener noreferrer">
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          )
        }
        <h2>FAQ</h2>
        <h3>Is this medical advice?</h3>
        <p>
          No. Educational research literacy only. Not a prescription or protocol for human use.
        </p>
        <h3>How should I read the evidence badge?</h3>
        <p>
          See our <a href="/evidence">evidence grades</a>. Animal or anecdotal tags mean you should not mentally
          upgrade the claim into proven human outcomes.
        </p>
        <h3>Was a clinician involved?</h3>
        <p>
          {reviewLabel}. Seat status and application notes live on <a href="/authors">Authors</a>. Standing quality
          criteria are on <a href="/resources/sourcing-notes">Sourcing notes</a>.
        </p>
      </div>
      <div class="continue-cluster">
        <h2>Continue in this path</h2>
        <ul>
          {
            continueLinks.map((link) => (
              <li>
                <a href={link.path}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
      <p class="disclaimer" style="margin-top: 2.5rem; max-width: var(--read);">
        Educational content only. Amino Brief does not provide medical advice, dosing protocols for human use,
        diagnosis, or treatment recommendations. Talk to a qualified clinician about health decisions.
      </p>
    </div>
  </article>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .guide-trust {
    display: grid;
    gap: 0.45rem;
    margin: 1rem 0 1.35rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
  }

  .guide-trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .guide-trust-row.mute {
    color: var(--mute);
  }

  .guide-review {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.88rem;
  }

  .continue-cluster {
    margin-top: 2.75rem;
    max-width: var(--read);
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }

  .continue-cluster h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .continue-cluster ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.45rem;
    font-family: var(--font-ui);
  }

  .continue-cluster a {
    text-decoration: none;
    font-weight: 600;
  }

  .continue-cluster a:hover {
    text-decoration: underline;
  }
</style>
