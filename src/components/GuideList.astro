---
import EvidenceBadge from './EvidenceBadge.astro';
import { clusterIdForGuide, seoClusters } from '../data/seo-clusters';

interface GuideItem {
  id: string;
  data: {
    title: string;
    description: string;
    category: string;
    evidence: string;
    tags: string[];
    pubDate: Date;
  };
}

interface Props {
  guides: GuideItem[];
}

const { guides } = Astro.props;

function clusterLabel(guide: GuideItem) {
  const id = clusterIdForGuide(guide);
  return seoClusters.find((c) => c.id === id)?.shortLabel || 'Literacy';
}
---

<ul class="link-list">
  {
    guides.map((guide) => (
      <li>
        <a href={`/guides/${guide.id}`}>
          <div class="meta">
            <EvidenceBadge level={guide.data.evidence} />
            <span style="margin-left: 0.5rem; text-transform: uppercase; letter-spacing: 0.08em;">
              {clusterLabel(guide)}
            </span>
          </div>
          <h3>{guide.data.title}</h3>
          <p style="margin: 0.35rem 0 0; color: var(--mute);">{guide.data.description}</p>
        </a>
      </li>
    ))
  }
</ul>
